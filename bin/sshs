#!/usr/bin/env bash
# Open multiple SSH connections in separate iTerm2 tabs
# Usage: sshs [host1 host2 ...] (default: auto-detected, excludes self)
#        sshs -L 8080:localhost:80 ep home
#        sshs -J ep -L 8080:localhost:80 home
#
# Each host also gets a per-host default -L (see hosts.json forward_port)
# for ad-hoc web previews on the remote (cargo doc, python -m http.server,
# etc.). User-supplied -L is added on top, not in place of, the default.
#
# Host registry lives in $XDG_CONFIG_HOME/sshs/hosts.json (override with
# SSHS_HOSTS_JSON). To add a new host, edit that file — sshs reads from it
# at startup, the script itself stays untouched.

set -euo pipefail

# ── Host registry: load from JSON ──
if ! command -v jq >/dev/null; then
  echo "Error: jq is required to parse hosts.json" >&2
  exit 1
fi

find_hosts_json() {
  if [ -n "${SSHS_HOSTS_JSON:-}" ] && [ -f "$SSHS_HOSTS_JSON" ]; then
    echo "$SSHS_HOSTS_JSON"; return
  fi
  local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/sshs/hosts.json"
  if [ -f "$cfg" ]; then
    echo "$cfg"; return
  fi
  # Fallback: when running directly from the dotfiles checkout.
  local script_dir; script_dir="$(cd "$(dirname "$0")" && pwd)"
  local repo_cfg="$script_dir/../config/sshs/hosts.json"
  if [ -f "$repo_cfg" ]; then
    echo "$repo_cfg"; return
  fi
  return 1
}

HOSTS_JSON="$(find_hosts_json)" || {
  echo "Error: hosts.json not found (looked at \$SSHS_HOSTS_JSON, \$XDG_CONFIG_HOME/sshs/hosts.json, and the dotfiles fallback)" >&2
  exit 1
}

ALL_HOSTS="$(jq -r '.hosts | keys_unsorted | join(" ")' "$HOSTS_JSON")"
DEFAULT_COLOR="$(jq -r '.default_color // "149 165 166"' "$HOSTS_JSON")"

# Per-host accessors. Each returns empty string if the field is missing
# instead of erroring out. macOS's stock /bin/bash is 3.2 and lacks
# associative arrays, so we keep all per-host data in hosts.json and look
# it up on demand instead of caching into `declare -A`.
host_field() { # $1 = alias, $2 = jq subexpression (e.g. .tailscale_name)
  jq -r --arg a "$1" ".hosts[\$a] | $2 // \"\"" "$HOSTS_JSON"
}

# ── Detect which host we are running on ──
alias_for_hostname() { # $1 = lowercase hostname; echoes alias or empty
  jq -r --arg h "$1" '
    .hosts | to_entries
    | map(select((.value.tailscale_name // "" | ascii_downcase) == $h))
    | .[0].key // ""
  ' "$HOSTS_JSON"
}

get_self_alias() {
  local h match
  h="$(hostname -s 2>/dev/null | tr '[:upper:]' '[:lower:]')"
  match="$(alias_for_hostname "$h")"
  if [ -n "$match" ]; then echo "$match"; return; fi

  # Fallback: ask Tailscale itself.
  local ts_cmd=""
  if command -v tailscale >/dev/null 2>&1; then
    ts_cmd="tailscale"
  elif [ -x "/Applications/Tailscale.app/Contents/MacOS/Tailscale" ]; then
    ts_cmd="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
  fi
  if [ -n "$ts_cmd" ]; then
    h="$("$ts_cmd" status --self --json 2>/dev/null \
      | jq -r '.Self.HostName // ""' \
      | tr '[:upper:]' '[:lower:]')"
    if [ -n "$h" ]; then
      match="$(alias_for_hostname "$h")"
      [ -n "$match" ] && echo "$match"
    fi
  fi
}

# ── Input validation ──
validate_safe() {
  local val="$1" label="$2"
  if [[ ! "$val" =~ ^[a-zA-Z0-9._:*/@,-]+$ ]]; then
    echo "Error: invalid characters in ${label}: ${val}" >&2
    exit 1
  fi
}

validate_port_forward() {
  local val="$1"
  if [[ ! "$val" =~ ^([a-zA-Z0-9.*-]+:)?[0-9]+:[a-zA-Z0-9._-]+:[0-9]+$ ]]; then
    echo "Error: invalid port forward spec: ${val}" >&2
    echo "Expected format: [bind_address:]port:host:hostport" >&2
    exit 1
  fi
}

validate_jump_host() {
  local val="$1"
  if [[ ! "$val" =~ ^[a-zA-Z0-9._@,-]+$ ]]; then
    echo "Error: invalid jump host spec: ${val}" >&2
    exit 1
  fi
}

# ── Parse arguments ──
ssh_opts=()
hosts=()
jump_host=""

while [ $# -gt 0 ]; do
  case "$1" in
    -J)
      if [ $# -lt 2 ]; then
        echo "Error: -J requires an argument" >&2
        exit 1
      fi
      validate_jump_host "$2"
      jump_host="$2"
      shift 2
      ;;
    -J*)
      jump_host="${1#-J}"
      validate_jump_host "$jump_host"
      shift
      ;;
    -L)
      if [ $# -lt 2 ]; then
        echo "Error: -L requires an argument" >&2
        exit 1
      fi
      validate_port_forward "$2"
      ssh_opts+=("-L" "$2")
      shift 2
      ;;
    -L*)
      local_fwd="${1#-L}"
      validate_port_forward "$local_fwd"
      ssh_opts+=("-L" "$local_fwd")
      shift
      ;;
    *)
      validate_safe "$1" "host"
      hosts+=("$1")
      shift
      ;;
  esac
done

# ── Default hosts: all except self ──
if [ ${#hosts[@]} -eq 0 ]; then
  self="$(get_self_alias)"
  for h in $ALL_HOSTS; do
    if [[ "$h" != "$self" ]]; then
      hosts+=("$h")
    fi
  done
fi

if [ ${#hosts[@]} -eq 0 ]; then
  echo "Error: no target hosts" >&2
  exit 1
fi

# ── Tab color ──
get_color() {
  local c
  c="$(host_field "$1" .color)"
  if [ -n "$c" ]; then echo "$c"; else echo "$DEFAULT_COLOR"; fi
}

# ── Build SSH options string ──
# User-supplied -L / -J apply to every host. The per-host default -L (cargo
# doc port, etc.) is computed inside the loop so it can vary by host.
# bash 3.2 (Apple's /bin/bash) errors on ${arr[*]} when the array was
# never assigned to, even with default substitution, so guard the read.
if [ "${#ssh_opts[@]}" -gt 0 ]; then
  common_opts_str="${ssh_opts[*]}"
else
  common_opts_str=""
fi
if [ -n "$jump_host" ]; then
  common_opts_str="-J ${jump_host}${common_opts_str:+ ${common_opts_str}}"
fi

# ── Open tabs ──
for host in "${hosts[@]}"; do
  read -r r g b <<< "$(get_color "$host")"
  fwd_port="$(host_field "$host" .forward_port)"
  ssh_cmd="ssh"
  if [ -n "$fwd_port" ]; then
    ssh_cmd="${ssh_cmd} -L ${fwd_port}:localhost:${fwd_port}"
  fi
  if [ -n "$common_opts_str" ]; then
    ssh_cmd="${ssh_cmd} ${common_opts_str}"
  fi
  ssh_cmd="${ssh_cmd} ${host}"
  osascript -e "
tell application \"iTerm2\"
  activate
  tell current window
    set newTab to (create tab with default profile)
    tell current session of newTab
      write text \"printf '\\\\e]6;1;bg;red;brightness;${r}\\\\a\\\\e]6;1;bg;green;brightness;${g}\\\\a\\\\e]6;1;bg;blue;brightness;${b}\\\\a'\"
      write text \"${ssh_cmd}\"
    end tell
  end tell
end tell
"
  # iTerm2's `tell current window` racey-ly drops tabs when osascript
  # invocations land back-to-back; pace them out a hair.
  sleep 0.25
done
